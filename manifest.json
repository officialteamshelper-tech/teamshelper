{
  "manifest_version": 3,
  "name": "Teams Helper",
  "version": "3.74.41",
  "minimum_chrome_version": "116",
  "description": "Set your Teams status and keep it there with schedules, manual status, logs, Teams account controls, and cloud sync.",
  "content_scripts": [
    {
      "matches": [
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*",
        "https://*.teams.cloud.microsoft/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*",
        "https://*.teams.cloud.microsoft/*"
      ],
      "js": [
        "page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://teams.live.com/*",
        "https://*.teams.live.com/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*",
        "https://*.teams.cloud.microsoft/*"
      ],
      "js": [
        "account_inventory.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "background",
    "alarms",
    "identity",
    "identity.email",
    "idle",
    "storage",
    "tabs",
    "scripting",
    "webRequest",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "cookies",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.account.live.com/*",
    "https://*.login.live.com/*",
    "https://*.login.microsoftonline.com/*",
    "https://*.microsoftonline.com/*",
    "https://*.teams.cloud.microsoft/*",
    "https://*.teams.live.com/*",
    "https://*.teams.microsoft.com/*",
    "https://*.workers.dev/*",
    "https://cfg.studytools.us/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://account.live.com/*",
    "https://login.live.com/*",
    "https://login.microsoftonline.com/*",
    "https://teams.cloud.microsoft/*",
    "https://teams.live.com/*",
    "https://teams.microsoft.com/*",
    "https://edge.skype.com/*",
    "https://*.edge.skype.com/*",
    "https://config.teams.microsoft.com/*",
    "https://*.config.teams.microsoft.com/*",
    "https://config.edge.skype.com/*",
    "https://*.config.edge.skype.com/*",
    "https://go.trouter.teams.microsoft.com/*",
    "https://*.trouter.teams.microsoft.com/*",
    "wss://*.trouter.teams.microsoft.com/*",
    "wss://go.trouter.teams.microsoft.com/*",
    "https://*.trouter.skype.com/*",
    "https://us-api.asm.skype.com/*",
    "https://experimental-api.asm.skype.com/*",
    "https://*.asm.skype.com/*",
    "https://go.trouter.skype.com/*",
    "wss://go.trouter.skype.com/*",
    "wss://*.trouter.skype.com/*",
    "https://augloop.office.com/*",
    "https://*.augloop.office.com/*",
    "wss://augloop.office.com/*",
    "wss://*.augloop.office.com/*",
    "https://*.asyncgw.teams.microsoft.com/*",
    "https://us-prod.asyncgw.teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://teams-presence-keeper-api.officialteamshelper.workers.dev/*"
    ]
  },
  "action": {
    "default_title": "Teams Helper",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
